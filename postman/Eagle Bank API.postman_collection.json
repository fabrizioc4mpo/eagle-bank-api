    {
      "name": "Authentication - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.environment.set(\"token\", jsonData.token);\r",
              "\r",
              "// Decode JWT payload\r",
              "let tokenParts = jsonData.token.split(\".\");\r",
              "let payload = JSON.parse(atob(tokenParts[1]));\r",
              "\r",
              "// Store userId from JWT subject\r",
              "pm.environment.set(\"userId\", payload.sub);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"email\": \"rickbarb@test.com\",\r\n  \"password\": \"Password123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/v1/auth/login",
          "protocol": "http",
